NEXT_PUBLIC_BACKEND_URL=https://api.suncarsrl.com

# Stripe Configuration (for payment links)
# Get your secret key from: https://dashboard.stripe.com/apikeys
# Use test key for development: sk_test_...
# Use live key for production: sk_live_...
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Enable Banking (banco español - solo lectura)
# Registro en: https://enablebanking.com
# Application ID de tu app en Enable Banking
ENABLE_BANKING_APP_ID=your_application_id_here
# Clave privada RSA en formato PEM, con los \n escapados como \\n
# Ejemplo: "-----BEGIN RSA PRIVATE KEY-----\\nMIIEow...\\n-----END RSA PRIVATE KEY-----"
ENABLE_BANKING_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour_key_here\n-----END RSA PRIVATE KEY-----"

# Chatwoot SSO (Suncar Whatsapp module)
# CHATWOOT_PLATFORM_API_TOKEN: token del Platform App creado en Chatwoot
# (PlatformApp.create!(name: 'SunCarAdmin').access_token.token)
CHATWOOT_BASE_URL=http://localhost:3000
CHATWOOT_PLATFORM_API_TOKEN=your_platform_api_token_here
CHATWOOT_ACCOUNT_ID=1
# Token personal de un usuario Chatwoot con rol administrator, usado solo
# para agregar agentes a las inboxes (la Platform API no cubre esto).
# Crear un usuario dedicado ("Integración SunCarAdmin") en vez de reusar
# la cuenta de una persona: User#access_token.token
CHATWOOT_ADMIN_ACCESS_TOKEN=your_admin_personal_access_token_here
