NEXT_PUBLIC_BACKEND_URL=https://api.suncarsrl.com

# Stripe Configuration (for payment links)
# Get your secret key from: https://dashboard.stripe.com/apikeys
# Use test key for development: sk_test_...
# Use live key for production: sk_live_...
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Enable Banking (banco español - solo lectura)
# Registro en: https://enablebanking.com
# Application ID de tu app en Enable Banking
ENABLE_BANKING_APP_ID=your_application_id_here
# Clave privada RSA en formato PEM, con los \n escapados como \\n
# Ejemplo: "-----BEGIN RSA PRIVATE KEY-----\\nMIIEow...\\n-----END RSA PRIVATE KEY-----"
ENABLE_BANKING_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour_key_here\n-----END RSA PRIVATE KEY-----"
